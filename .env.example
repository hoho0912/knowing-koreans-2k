# knowing-koreans 환경변수 템플릿
# 실제 .env.local 파일에 값 채우고 git에 커밋하지 않을 것 (.gitignore 등재)

# OpenAI 직접 호출용
OPENAI_API_KEY=sk-...

# OpenRouter (다중 모델 fallback)
OPENROUTER_API_KEY=sk-or-v1-...

# Hugging Face (선택 — 공개 데이터셋이라 비필수, rate limit 회피용)
HF_TOKEN=hf_...

# Ollama 로컬 (기본값 충분, 다른 호스트면 변경)
OLLAMA_HOST=http://localhost:11434

# 프로젝트 설정
PROJECT_ROOT=/Users/hosan_korea/Work/projects/knowing-koreans
NEMOTRON_LOCAL_DIR=./backend/nvidia-personas
RESULTS_DIR=./backend/results
